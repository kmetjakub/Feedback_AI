datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  feedback  Feedback[]
  insight   Insight?
}

model Insight {
  id          Int      @id @default(autoincrement())
  projectId   Int      @unique
  project     Project  @relation(fields: [projectId], references: [id])
  data        Json
  generatedAt DateTime @default(now())
}

model Feedback {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String?
  category  String
  text      String
  createdAt DateTime @default(now())
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])
}
